# 中文注释：
# 1) 本文件仅供 bbu5900_dual_upf_vonr 场景使用
# 2) 部署前务必修改 DOCKER_HOST_IP、TEST_NETWORK、UPF/IMS_UPF 相关地址
# 3) internet APN 走 eUPF，ims APN 走原生 Open5GS UPF
# Set proper timezone to sync times between docker host and containers
#TZ=Europe/Berlin

MCC=001
MNC=01
TAC=1

TEST_NETWORK=172.22.0.0/24
DOCKER_HOST_IP=192.168.1.188

# MONGODB
MONGO_IP=172.22.0.2

# HSS - open5gs
HSS_IP=172.22.0.3

# PCRF
PCRF_IP=172.22.0.4
PCRF_BIND_PORT=3873

# SGW
SGWC_IP=172.22.0.5
SGWU_IP=172.22.0.6
SGWU_ADVERTISE_IP=172.22.0.6

# SMF
SMF_IP=172.22.0.7
SMF_DNS1=8.8.8.8
SMF_DNS2=8.8.4.4

# UPF
# eUPF for internet APN
UPF_IP=172.22.0.8
# eUPF PFCP(N4)地址（SMF访问），host网络模式下使用ens38地址
UPF_PFCP_IP=10.10.10.101
# eUPF N3广播地址 → ens38 (10.10.10.101), gNB通过此IP发送internet N3 GTP-U
UPF_ADVERTISE_IP=10.10.10.101
# Native Open5GS UPF for ims APN
IMS_UPF_IP=172.22.0.90
# IMS UPF N3广播地址 → ens37 (10.10.10.100), gNB通过此IP发送IMS N3 GTP-U
IMS_UPF_ADVERTISE_IP=10.10.10.100
IMS_UPF_TUNTAP_MODE=tun
IMS_UPF_APN_IF_NAME=ogstun2

# MME
MME_IP=172.22.0.9

# AMF
AMF_IP=172.22.0.10

# AUSF
AUSF_IP=172.22.0.11

# NRF
NRF_IP=172.22.0.12

# UDM
UDM_IP=172.22.0.13

# UDR
UDR_IP=172.22.0.14

# IMS DNS
DNS_IP=172.22.0.15

# RTPENGINE
RTPENGINE_IP=172.22.0.16

# MYSQL
MYSQL_IP=172.22.0.17

# PYHSS
PYHSS_IP=172.22.0.18
PYHSS_BIND_PORT=3875

# ICSCF
ICSCF_IP=172.22.0.19
ICSCF_BIND_PORT=3869

# SCSCF
SCSCF_IP=172.22.0.20
SCSCF_BIND_PORT=3870

# PCSCF
PCSCF_IP=172.22.0.21
PCSCF_BIND_PORT=3871

# OPEN5GS WEBUI
WEBUI_IP=172.22.0.26

# PCF
PCF_IP=172.22.0.27

# NSSF
NSSF_IP=172.22.0.28

# BSF
BSF_IP=172.22.0.29

# ENTITLEMENT SERVER
ENTITLEMENT_SERVER_IP=172.22.0.30

# OSMOMSC
OSMOMSC_IP=172.22.0.31

# OSMOHLR
OSMOHLR_IP=172.22.0.32

# SMSC
SMSC_IP=172.22.0.33

# SCP
SCP_IP=172.22.0.35

# METRICS
METRICS_IP=172.22.0.36

# IBCF 
IBCF_IP=172.22.0.140

# GRAFANA
GRAFANA_IP=172.22.0.39
GRAFANA_USERNAME=open5gs
GRAFANA_PASSWORD=open5gs

# OCS
OCS_IP=172.22.0.40
OCS_BIND_PORT=3872

# OSMOEPDG
OSMOEPDG_IP=172.22.0.41

# SWU CLIENT
SWU_CLIENT_IP=172.22.0.42

# UE IPv4 Subnet Range for APN=internet
UE_IPV4_INTERNET=10.45.0.0/16

# UE IPv4 Subnet Range for APN=ims
UE_IPV4_IMS=10.46.0.0/16

# Host policy-routing for UE subnets (N6 egress)
# 建议：N6_IF 对应外网出口网卡（例如 ens39），N6_GATEWAY 为该网段网关
N6_IF=ens39
N6_GATEWAY=192.168.2.254
UE_POLICY_TABLE=245
UE_POLICY_PRIO_INTERNET=10045
UE_POLICY_PRIO_IMS=10046

# Maximum Number of UEs
MAX_NUM_UE=1024
